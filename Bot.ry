# ====== ЕСЛИ НЕ ПОНЯЛ КОМАНДУ ======
@bot.message_handler(func=lambda message: True)
def fallback(message):
    bot.send_message(
        message.chat.id,
        "❌ Команда не распознана.\n\n"
        "Нажми /start чтобы открыть меню.",
        reply_markup=main_menu()
    )

