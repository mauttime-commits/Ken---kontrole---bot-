import os
import telebot
from telebot import types

TOKEN = os.getenv("8705606322:AAEBR17-N_jwKAgbgNDivfPi0SIn0h6rfao")
bot = telebot.TeleBot(8705606322:AAEBR17-N_jwKAgbgNDivfPi0SIn0h6rfao)

# ====== КЛАВИАТУРА ======
def main_menu():
    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
    btn1 = types.KeyboardButton("📢 Объявления")
    btn2 = types.KeyboardButton("📋 Собрания")
    btn3 = types.KeyboardButton("🛡 Администрация")
    btn4 = types.KeyboardButton("📝 Шаблоны")
    btn5 = types.KeyboardButton("👑 Руководство")
    btn6 = types.KeyboardButton("📞 Контакты")
    markup.add(btn1, btn2)
    markup.add(btn3, btn4)
    markup.add(btn5, btn6)
    return markup

# ====== /START ======
@bot.message_handler(commands=['start'])
def start(message):
    bot.send_message(
        message.chat.id,
        "🔥 *KentRP Control Bot запущен!*\n\n"
        "Добро пожаловать в панель управления проектом.\n"
        "Выбери нужный раздел через кнопки ниже 👇",
        parse_mode="Markdown",
        reply_markup=main_menu()
    )

# ====== /HELP ======
@bot.message_handler(commands=['help'])
def help_cmd(message):
    bot.send_message(
        message.chat.id,
        "📌 *Доступные команды:*\n\n"
        "/start — открыть главное меню\n"
        "/help — список команд\n\n"
        "Также можно использовать кнопки внизу 👇",
        parse_mode="Markdown",
        reply_markup=main_menu()
    )

